#!/bin/sh
# ──────────────────────────────────────────────────────────────
# 비밀키 유출 방지 pre-commit 훅 (명운록 / 자동 설치)
# 스테이징된 변경에서 .env 파일이나 실제 API 키 패턴을 탐지하면 커밋을 막는다.
# 의도된 커밋이면:  git commit --no-verify
# ──────────────────────────────────────────────────────────────
fail=0

# 1) 실수로 staged 된 .env 계열 차단 (.env.example 만 허용)
staged_env=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)\.env' | grep -vE '\.env\.example$' || true)
if [ -n "$staged_env" ]; then
  echo "✋ 커밋 차단: .env 파일이 스테이징됐습니다 (비밀키 위험)"
  echo "$staged_env" | sed 's/^/    /'
  echo "   해결:  git rm --cached <파일>   또는   git reset <파일>"
  fail=1
fi

# 2) 추가된(+) 라인에서 실제 키 패턴 탐지
added=$(git diff --cached --diff-filter=ACM -U0 | grep -E '^\+' | grep -vE '^\+\+\+' || true)
patterns='sk-proj-[A-Za-z0-9_-]{20}|sk-ant-[A-Za-z0-9_-]{20}|AIza[0-9A-Za-z_-]{30}|sb_secret_[A-Za-z0-9]{8}|live_g[sc]k_[A-Za-z0-9]{8}|-----BEGIN [A-Z ]*PRIVATE KEY-----'
hits=$(printf '%s\n' "$added" | grep -noE "$patterns" || true)
if [ -n "$hits" ]; then
  echo "✋ 커밋 차단: 실제 비밀키로 의심되는 문자열이 포함됐습니다"
  printf '%s\n' "$hits" | sed 's/^/    /'
  echo "   → 키는 .env 에만 두세요. .env.example 엔 빈 placeholder만 넣습니다."
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "정말 의도한 커밋이라면(예: 문서의 공개 예시):  git commit --no-verify"
  exit 1
fi
exit 0
