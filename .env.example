# =====================================================
# 사주 사이트 보일러플레이트 - 환경변수
# =====================================================
# 모든 키 발급처와 자세한 설명은 README.md 의 "환경변수 발급처" 표 참고.

# ─── Site ────────────────────────────────────────────
# 배포 도메인. 로컬은 http://localhost:3000 그대로.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── 방문자/행동 분석 ────────────────────────────────
# 방문자수·퍼널 이탈·유입경로는 자체 수집(/api/track → analytics_events)되어
# /admin/analytics 에서 봅니다. 별도 설정 불필요(마이그레이션 0007만 적용).
#
# Microsoft Clarity(선택·무료): '왜 이탈하는지'를 세션 녹화·히트맵으로 보고 싶을 때만.
# 비워두면 로드되지 않습니다(자체 분석은 그대로 동작).
# https://clarity.microsoft.com → 프로젝트 생성 → 프로젝트 ID. (입력값 마스킹 기본 유지)
NEXT_PUBLIC_CLARITY_ID=

# ─── Supabase ────────────────────────────────────────
# 발급: https://supabase.com → 프로젝트 생성 → Settings → API Keys
#
# 2025-07 부터 신 키 시스템 (publishable / secret) 정식 출시.
#   • publishable: sb_publishable_...  (구 anon JWT 대체)
#   • secret:      sb_secret_...       (구 service_role JWT 대체)
# 구 anon / service_role JWT 도 그대로 동작하나 2026 말 deprecated/삭제 예정.
# 신규 프로젝트는 publishable / secret 키만 받습니다 (2025-11 이후).
#
# secret 키는 절대 클라이언트에 노출 금지 — 서버 라우트에서만 사용.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ─── 토스페이먼츠 ────────────────────────────────────
# 발급: https://developers.tosspayments.com → 내 상점 → API 키
# 아래는 토스 공식 docs 공개 테스트 키 — 회원가입/사업자번호 없이 즉시 결제 테스트 가능.
# 실 결제용 라이브 키는 PG 심사 통과 후 발급 (./PG_심사_가이드.md 참고).
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# ─── 만세력 API (간이, 선택) ────────────────────────
# 자체 만세력 API 가 있다면 여기에 (어댑터: src/lib/saju/manseryeok.ts)
# 비워두면 mock 데이터를 반환합니다 (luckyloveme API 가 메인이라 보통 비워둠).
MANSERYEOK_API_URL=
MANSERYEOK_API_KEY=

# ─── 사주 풀 분석 API (luckyloveme) ─────────────────
# 발급: https://luckyloveme.com/api-service
# 사주 명식표 + 16종 풀 분석 (천간지지/십성/대운/세운/12운성/신살 등).
# 가이드: ./운세위키_API_가이드.md
# 어댑터: src/lib/saju/saju-api.ts / 라우트: /api/generate-manseryeok
# 헤더: X-SAJU-BOOK-API-KEY + User-Agent: SajuBookClient/1.0 (어댑터 자동 처리)
# 누적 한도 6,000회 — /admin 홈에서 누적 카운터 확인 가능.
# 미설정 시 /api/generate-manseryeok 은 503 / /demo 명식도 안 나옴.
SAJU_API_URL=https://luckyloveme.com/api/saju-full-analysis
SAJU_API_KEY=

# ─── LLM ─────────────────────────────────────────────
# LLM_PROVIDER: openai | anthropic | gemini 중 택 1
# 해당 provider 의 키만 채우면 됩니다 (안 쓰는 SDK 는 lazy import 라 부하 0).
# 발급:
#   • ANTHROPIC_API_KEY → https://console.anthropic.com/settings/keys
#   • OPENAI_API_KEY    → https://platform.openai.com/api-keys
#   • GOOGLE_GENERATIVE_AI_API_KEY → https://aistudio.google.com/app/apikey
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── 어드민 ──────────────────────────────────────────
# /admin 진입 비밀번호. 기본값은 0000 — 운영 전 강력한 값으로 반드시 변경하세요.
# 예: ADMIN_PASSWORD=hanna-secret-2026
ADMIN_PASSWORD=0000

# ─── 복구 크론 ───────────────────────────────────────
# 결제는 됐는데 결과지가 안 만들어진 주문을 주기적으로 재생성하는 크론의 인증 키.
# 임의의 긴 랜덤 문자열로 채우세요. 예: CRON_SECRET=$(openssl rand -hex 32)
# Vercel 배포 시 같은 값을 환경변수로 등록하면 Vercel Cron 이 자동으로
#   Authorization: Bearer <CRON_SECRET> 헤더를 붙여 호출합니다(vercel.json 의 crons).
# 비워두면 /api/cron/recover-results 는 비활성(401) 입니다.
CRON_SECRET=
